<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg"
    android:padding="30dp">

    <TextView
        android:id="@+id/parentLessonsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мои занятия"
        android:textColor="@color/text_dark"
        android:textSize="30sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/parentLessonsTabs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/parentFutureTab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_orange"
            android:paddingHorizontal="18dp"
            android:paddingVertical="8dp"
            android:text="Будущие"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/parentMissedTab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_tab_inactive"
            android:paddingHorizontal="18dp"
            android:paddingVertical="8dp"
            android:text="Пропуски"
            android:textColor="@color/text_dark"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/parentLessonsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />

    <TextView
        android:id="@+id/emptyLessonsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ближайшие занятия не найдены"
        android:textColor="@color/hint_gray"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>